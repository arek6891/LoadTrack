generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  IN_STOCK
  LOADED
  ERROR
}

enum Role {
  ADMIN
  LEADER
  OPERATOR
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      Role     @default(OPERATOR)
  logs      AuditLog[]
  createdAt DateTime @default(now())
}

enum EntityType {
  PACKAGE
  PALLET
  LOADING
  USER
  LOCATION
  TEMPLATE
}

model AuditLog {
  id        String     @id @default(uuid())
  entity    EntityType
  entityId  String
  action    String
  details   String?
  userId    String?
  user      User?      @relation(fields: [userId], references: [id])
  createdAt DateTime   @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

enum LoadingStatus {
  OPEN
  CLOSED
}

model Package {
  id             String   @id @default(uuid())
  trackingNumber String   @unique
  palletId       String?
  pallet         Pallet?  @relation(fields: [palletId], references: [id])
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])
  status         Status   @default(IN_STOCK)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([palletId])
  @@index([locationId])
  @@index([createdAt])
}

model Pallet {
  id           String   @id @default(uuid())
  palletNumber String   @unique
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])
  loadingId    String?
  loading      Loading? @relation(fields: [loadingId], references: [id])
  status       Status   @default(IN_STOCK)
  packages     Package[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([loadingId])
  @@index([locationId])
  @@index([createdAt])
}

model Location {
  id       String    @id @default(uuid())
  name     String    @unique
  packages Package[]
  pallets  Pallet[]
}

model Loading {
  id                  String        @id @default(uuid())
  driverName          String
  vehicleRegistration String
  status              LoadingStatus @default(OPEN)
  pallets             Pallet[]
  expectedPallets     String[]      @default([])
  createdAt           DateTime      @default(now())
  closedAt            DateTime?

  @@index([status, closedAt])
  @@index([driverName])
  @@index([vehicleRegistration])
  @@index([createdAt])
}

enum TemplateType {
  PACKAGE
  PALLET
}

model LabelTemplate {
  id          String       @id @default(uuid())
  name        String       @unique
  type        TemplateType @default(PACKAGE)
  htmlContent String       @db.Text
  cssContent  String       @db.Text
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}
