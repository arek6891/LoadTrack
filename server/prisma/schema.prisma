generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  IN_STOCK
  LOADED
  ERROR
}

enum LoadingStatus {
  OPEN
  CLOSED
}

model Package {
  id             String   @id @default(uuid())
  trackingNumber String   @unique
  palletId       String?
  pallet         Pallet?  @relation(fields: [palletId], references: [id])
  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])
  status         Status   @default(IN_STOCK)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Pallet {
  id           String   @id @default(uuid())
  palletNumber String   @unique
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])
  loadingId    String?
  loading      Loading? @relation(fields: [loadingId], references: [id])
  status       Status   @default(IN_STOCK)
  packages     Package[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Location {
  id       String    @id @default(uuid())
  name     String    @unique
  packages Package[]
  pallets  Pallet[]
}

model Loading {
  id                  String        @id @default(uuid())
  driverName          String
  vehicleRegistration String
  status              LoadingStatus @default(OPEN)
  pallets             Pallet[]
  createdAt           DateTime      @default(now())
  closedAt            DateTime?
}
